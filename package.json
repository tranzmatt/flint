{
  "name": "flint",
  "productName": "Flint",
  "description": "Local AI Knowledge Base",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "package": "node scripts/build-app.js"
  },
  "dependencies": {
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/suggestion": "^3.27.1",
    "clsx": "2.1.1",
    "lucide-react": "^1.8.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "3.4.0",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-singlefile": "2.3.0"
  },
  "build": {
    "appId": "com.flint.app",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/flint-logo.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/flint-logo.png"
    },
    "directories": {
      "output": "dist_electron"
    },
    "asarUnpack": [
      "electron/bin/**/*"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  }
}
